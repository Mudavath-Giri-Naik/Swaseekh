  {
    "sourceQNum": 4,
    "questionText": "Which of the following has the most number of divisors?",
    "questionType": "mcq",
    "options": [
      "A) 99",
      "B) 101",
      "C) 176",
      "D) 182"
    ],
    "correctAnswer": "C) 176",
    "difficulty": "medium",
    "solution": {
      "steps": [
        {
          "stepNumber": 1,
          "explanation": "Find the number of divisors of 99. $99 = 3^2 \\times 11^1$. Number of divisors = $(2+1)(1+1) = 6$.",
          "formula": "Divisor count formula",
          "formulaExpression": "\\tau(n) = (e_1+1)(e_2+1)\\cdots \\text{ if } n = p_1^{e_1} p_2^{e_2}\\cdots",
          "calculation": "99 = 3^2 \\times 11^1 \\Rightarrow \\tau(99) = (2+1)(1+1) = 6",
          "result": "6 divisors"
        },
        {
          "stepNumber": 2,
          "explanation": "Find the number of divisors of 101. 101 is prime, so it has exactly 2 divisors.",
          "formula": null,
          "formulaExpression": "",
          "calculation": "101 \\text{ is prime} \\Rightarrow \\tau(101) = 2",
          "result": "2 divisors"
        },
        {
          "stepNumber": 3,
          "explanation": "Find the number of divisors of 176. $176 = 2^4 \\times 11^1$. Number of divisors = $(4+1)(1+1) = 10$.",
          "formula": null,
          "formulaExpression": "",
          "calculation": "176 = 2^4 \\times 11^1 \\Rightarrow \\tau(176) = (4+1)(1+1) = 10",
          "result": "10 divisors"
        },
        {
          "stepNumber": 4,
          "explanation": "Find the number of divisors of 182. $182 = 2 \\times 7 \\times 13$. Number of divisors = $(1+1)(1+1)(1+1) = 8$.",
          "formula": null,
          "formulaExpression": "",
          "calculation": "182 = 2^1 \\times 7^1 \\times 13^1 \\Rightarrow \\tau(182) = (1+1)(1+1)(1+1) = 8",
          "result": "8 divisors"
        },
        {
          "stepNumber": 5,
          "explanation": "Compare: 6, 2, 10, 8. The maximum is 10, corresponding to 176.",
          "formula": null,
          "formulaExpression": "",
          "calculation": "\\max(6, 2, 10, 8) = 10 \\Rightarrow 176",
          "result": "176 has the most divisors"
        }
      ],
      "shortcut": "Use the formula tau(n) = product of (exponent+1) after prime factorisation to count divisors quickly.",
      "commonMistake": "Listing divisors manually instead of using the exponent formula, leading to counting errors.",
      "timeToSolve": "90 seconds"
    },
    "modelName": "Number of divisors using prime factorisation",
    "formulas": [
