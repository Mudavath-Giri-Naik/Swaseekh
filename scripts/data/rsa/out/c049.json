    "sourceQNum": 28,
    "questionText": "If $x = \\dfrac{\\sqrt{5}+\\sqrt{3}}{\\sqrt{5}-\\sqrt{3}}$ and $y = \\dfrac{\\sqrt{5}-\\sqrt{3}}{\\sqrt{5}+\\sqrt{3}}$, find the value of $x^2 + y^2$.",
    "questionType": "integer",
    "options": null,
    "correctAnswer": "62",
    "difficulty": "hard",
    "solution": {
      "steps": [
        {
          "stepNumber": 1,
          "explanation": "Rationalize x by multiplying numerator and denominator by the conjugate of the denominator.",
          "formula": null,
          "formulaExpression": "x = \\frac{(\\sqrt{5}+\\sqrt{3})^2}{(\\sqrt{5}-\\sqrt{3})(\\sqrt{5}+\\sqrt{3})}",
          "calculation": "x = \\frac{5 + 3 + 2\\sqrt{15}}{5 - 3} = \\frac{8 + 2\\sqrt{15}}{2} = 4 + \\sqrt{15}",
          "result": "$x = 4 + \\sqrt{15}$"
        },
        {
          "stepNumber": 2,
          "explanation": "Similarly rationalize y.",
          "formula": null,
          "formulaExpression": "y = \\frac{(\\sqrt{5}-\\sqrt{3})^2}{(\\sqrt{5}+\\sqrt{3})(\\sqrt{5}-\\sqrt{3})}",
          "calculation": "y = \\frac{5 + 3 - 2\\sqrt{15}}{2} = \\frac{8 - 2\\sqrt{15}}{2} = 4 - \\sqrt{15}",
          "result": "$y = 4 - \\sqrt{15}$"
        },
        {
          "stepNumber": 3,
          "explanation": "Compute $x^2 + y^2$ using the identity $a^2 + b^2 = (a+b)^2 - 2ab$.",
          "formula": null,
          "formulaExpression": "x^2 + y^2 = (4+\\sqrt{15})^2 + (4-\\sqrt{15})^2",
          "calculation": "= 2[(4)^2 + (\\sqrt{15})^2] = 2[16 + 15] = 2 \\times 31 = 62",
          "result": "$x^2 + y^2 = 62$"
        }
      ],
      "shortcut": "Use identity $a^2 + b^2 = 2[(\\text{Re part})^2 + (\\text{Im part})^2]$ after rationalization.",
      "commonMistake": "Forgetting to rationalize fully before squaring.",
      "timeToSolve": "3 min"
    },
    "modelName": "Rationalization & Surds Algebra",
    "formulas": [
      {"title": "Sum of squares via conjugates", "expression": "a^2 + b^2 = 2(m^2 + n^2) \\text{ when } a=m+n,\\ b=m-n"},
