    "difficulty": "medium",
    "solution": {
      "steps": [
        {
          "stepNumber": 1,
          "explanation": "Let spectators on Monday, Tuesday, Wednesday be $2p$, $3p$, $5p$ and prices be $2q$, $3q$, $4q$ respectively.",
          "formula": null,
          "formulaExpression": "\\text{Amount} = \\text{Spectators} \\times \\text{Price}",
          "calculation": "Monday: 2p × 2q = 4pq; Tuesday: 3p × 3q = 9pq; Wednesday: 5p × 4q = 20pq",
          "result": "Amounts: 4pq, 9pq, 20pq"
        },
        {
          "stepNumber": 2,
          "explanation": "Use the condition: amount on Wednesday − amount on Tuesday = Rs. 8800",
          "formula": null,
          "formulaExpression": "20pq - 9pq = 8800",
          "calculation": "11pq = 8800",
          "result": "pq = 800"
        },
        {
          "stepNumber": 3,
          "explanation": "Calculate total amount earned across all three days",
          "formula": null,
          "formulaExpression": "4pq + 9pq + 20pq = 33pq",
          "calculation": "33 × 800",
          "result": "₹ 26400"
        }
      ],
