          "formula": null,
          "formulaExpression": "\\frac{l_1}{r_1^2} = \\frac{l_2}{r_2^2}",
          "calculation": "",
          "result": "Equal resistance condition"
        },
        {
          "stepNumber": 2,
          "explanation": "Radii in ratio 9:8, so r₁ = 9x, r₂ = 8x. l₁ = 162 cm.",
          "formula": null,
          "formulaExpression": "\\frac{162}{(9x)^2} = \\frac{l_2}{(8x)^2}",
          "calculation": "\\frac{162}{81} = \\frac{l_2}{64} \\Rightarrow l_2 = \\frac{162 \\times 64}{81} = 2 \\times 64",
          "result": "l₂ = 128 cm"
        }
      ],
      "shortcut": "l₂ = l₁ × (r₂/r₁)² = 162 × (8/9)² = 162 × 64/81 = 128.",
