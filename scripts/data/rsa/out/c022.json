    "questionText": "If $x$ is an integer such that $x + \\frac{1}{x} = \\frac{17}{4}$, find the value of $x - \\frac{1}{x}$.",
    "questionType": "integer",
    "options": null,
    "correctAnswer": "$\\frac{15}{4}$",
    "difficulty": "medium",
    "solution": {
      "steps": [
        {
          "stepNumber": 1,
          "explanation": "Square both sides of the given equation.",
          "formula": "Squaring sum",
          "formulaExpression": "\\left(x + \\frac{1}{x}\\right)^2 = x^2 + 2 + \\frac{1}{x^2} = \\left(\\frac{17}{4}\\right)^2 = \\frac{289}{16}",
          "calculation": "x^2 + \\frac{1}{x^2} = \\frac{289}{16} - 2 = \\frac{289 - 32}{16} = \\frac{257}{16}",
          "result": "$x^2 + \\frac{1}{x^2} = \\frac{257}{16}$"
        },
        {
          "stepNumber": 2,
          "explanation": "Use the identity $(x - 1/x)^2 = x^2 - 2 + 1/x^2$.",
          "formula": "Squaring difference",
          "formulaExpression": "\\left(x - \\frac{1}{x}\\right)^2 = x^2 + \\frac{1}{x^2} - 2 = \\frac{257}{16} - 2 = \\frac{257 - 32}{16} = \\frac{225}{16}",
          "calculation": "\\left(x - \\frac{1}{x}\\right)^2 = \\frac{225}{16}",
          "result": "$\\frac{225}{16}$"
        },
        {
          "stepNumber": 3,
          "explanation": "Take the square root.",
          "formula": null,
          "formulaExpression": "x - \\frac{1}{x} = \\frac{15}{4}",
          "calculation": "\\sqrt{\\frac{225}{16}} = \\frac{15}{4}",
          "result": "$\\frac{15}{4}$"
        }
      ],
      "shortcut": "$(x - 1/x)^2 = (x + 1/x)^2 - 4 = (17/4)^2 - 4 = 225/16$, so answer is $15/4$.",
      "commonMistake": "Forgetting to subtract 2 (or 4) when going from $(x+1/x)^2$ to $(x-1/x)^2$.",
      "timeToSolve": "60 seconds"
    },
    "modelName": "Algebraic identity x+1/x to x-1/x",
    "formulas": [
