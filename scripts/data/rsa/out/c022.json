          "formula": null,
          "formulaExpression": "",
          "calculation": "",
          "result": ""
        },
        {
          "stepNumber": 2,
          "explanation": "Total mornings = total afternoons (same number of days), so 12 + M = 13 + A giving M - A = 1.",
          "formula": null,
          "formulaExpression": "M - A = 1 \\quad \\text{...(i)}",
          "calculation": "",
          "result": ""
        },
        {
          "stepNumber": 3,
          "explanation": "Total meetings = M + A = 15.",
          "formula": null,
          "formulaExpression": "M + A = 15 \\quad \\text{...(ii)}",
          "calculation": "",
          "result": ""
        },
        {
          "stepNumber": 4,
          "explanation": "Add (i) and (ii): 2M = 16, M = 8. Duration = 12 + 8 = 20 days.",
          "formula": null,
          "formulaExpression": "",
          "calculation": "M = 8,\\ \\text{Duration} = 12 + 8 = 20",
          "result": "20 days"
        }
      ],
